# MongoDB Atlas connection string — MUST include the database name
DATABASE=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/Aura-Rare-Beauty?retryWrites=true&w=majority
PORT=8000

# Cloudinary (image storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Auth — set a long random string in production
JWT_SECRET=

# Comma-separated allowed origins in production, e.g. https://aurarare.vercel.app
CORS_ORIGINS=
